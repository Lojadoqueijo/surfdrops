# === Fontes de dados de mercado (ver DEFI_SURFERS_PLANO.md §3.5) ===
# Cripto: Binance API pública — NÃO precisa de chave (CoinGecko como fallback, idem).
# Ações/ETFs/commodities/índices: Twelve Data, plano Basic grátis (800/dia, 8/min).
TWELVEDATA_API_KEY=

# Forçar dados mock (dev/preview sem credenciais): USE_MOCK=1
USE_MOCK=

# === Discord OAuth + verificação de cargo (valores públicos já conhecidos) ===
# App criada 2026-07-02 — ver DEFI_SURFERS_PLANO.md §3
DISCORD_CLIENT_ID=1522367057671491685
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=1193216608030687284
# Aceita vários IDs separados por vírgula (cargo base, Adm, #1...) — basta ter um.
DISCORD_ROLE_ID=1193224247573741699

# === Cron (proteção do endpoint /api/cron/refresh) ===
CRON_SECRET=

# === Base de dados (Bloco C.9 — Supabase, projeto ainda por criar) ===
